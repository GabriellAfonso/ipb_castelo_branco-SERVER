### Variáveis Globais
@baseUrl = http://localhost:8000
@prodUrl = https://gabrielafonso.com.br/api
@json = application/json
@loginToken = {{login.response.body.access}}

# region 🔓 AUTENTICAÇÃO
### Registrar usuário
# @name register
POST {{baseUrl}}/api/auth/register/
Content-Type: {{json}}

{
  "username": "gabriel_test",
  "first_name": "Teste",
  "last_name": "JWT",
  "password": "12345678",
  "password_confirm": "12345678"
}

### Login
# @name login
POST {{baseUrl}}/api/auth/login/
Content-Type: {{json}}

{
  "username": "gabriel_test",
  "password": "12345678"
}

### Refresh Token
# @name refresh
POST {{baseUrl}}/api/auth/refresh/
Content-Type: {{json}}

{
  "refresh": "{{login.response.body.refresh}}"
}
# endregion

# region 📸 GALLERY
### Listar todas as fotos
GET {{baseUrl}}/api/photos/
Content-Type: {{json}}

### Listar fotos de um álbum específico (por ID)
GET {{baseUrl}}/api/albums/1/photos/
Content-Type: {{json}}

### Upload de fotos (Gambiarra)
POST {{baseUrl}}/api/gallery/upload/
Authorization: Bearer {{loginToken}}
Content-Type: multipart/form-data

file=@./imagem_teste.jpg
# endregion

# region 👤 USUÁRIO
### Obter perfil
GET {{baseUrl}}/api/me/profile/
Authorization: Bearer {{loginToken}}
Content-Type: {{json}}

### Upload foto de perfil
POST {{baseUrl}}/api/me/profile/photo/
Authorization: Bearer {{loginToken}}
Content-Type: multipart/form-data

photo=@./profile.jpg
# endregion

# region 🎵 MÚSICAS E ESTATÍSTICAS
### Listar todas as músicas (All Songs)
# @name all_songs
GET {{baseUrl}}/api/songs/
Content-Type: {{json}}

### Músicas por domingo
GET {{baseUrl}}/api/songs-by-sunday/
Content-Type: {{json}}

### Top músicas
GET {{baseUrl}}/api/top-songs/
Content-Type: {{json}}

### Top tonalidades
GET {{baseUrl}}/api/top-tones/
Content-Type: {{json}}

### Músicas sugeridas
GET {{baseUrl}}/api/suggested-songs/
Content-Type: {{json}}

### Músicas sugeridas (fixando posições 1 e 3)
GET {{baseUrl}}/api/suggested-songs/?fixed=1:176,2:107
Content-Type: {{json}}
# endregion

# region 📖 HINÁRIO
### Hinário (local)
GET {{baseUrl}}/api/hymnal/
Content-Type: {{json}}

### Hinário (produção)
GET {{prodUrl}}/api/hymnal/
Content-Type: {{json}}
# endregion

# region 🗓️ ESCALA (novo fluxo)
### 1) Buscar escala do mês atual
# @name schedule_current
GET {{baseUrl}}/api/schedule/current/
Content-Type: {{json}}

### 2) Gerar preview do próximo mês
# @name schedule_preview
POST {{baseUrl}}/api/schedule/preview/
Content-Type: {{json}}

{}

### 3) Regerar preview fixando itens
# @name schedule_preview_fixed
POST {{baseUrl}}/api/schedule/preview/
Content-Type: {{json}}

{
  "year": 2026,
  "month": 3,
  "fixed": [
    { "schedule_type_id": 3, "date": "2026-03-01", "member_id": 10 },
    { "schedule_type_id": 2, "date": "2026-03-05", "member_id": 8 }
  ]
}

### 4) Salvar a escala
POST {{baseUrl}}/api/schedule/save/
Content-Type: {{json}}

{
  "year": {{schedule_preview.response.body.year}},
  "month": {{schedule_preview.response.body.month}},
  "items": {{schedule_preview.response.body.items}}
}
# endregion

# region ✅ ADMIN & UTILIDADES
### Registrar Played para um domingo
# @name register_played
POST {{baseUrl}}/api/played/register/
Authorization: Bearer {{loginToken}}
Content-Type: {{json}}

{
  "date": "2026-02-07",
  "plays": [
    { "song_id": 1, "position": 1, "tone": "G" },
    { "song_id": 2, "position": 2, "tone": "A" }
  ]
}

### Preencher tabelas (produção)
GET {{prodUrl}}/api/fill-tables/
Content-Type: {{json}}
# endregion